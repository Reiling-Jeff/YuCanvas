<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YuCanvas.Models"
             xmlns:views="clr-namespace:YuCanvas.Views"
             xmlns:viewModels="clr-namespace:YuCanvas.Models.ViewModels"
             x:Class="YuCanvas.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Styles/Colors.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    
    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AssignmentsViewModel}">
            <views:AssignmentsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:AssignmentDetailViewModel}">
            <views:AssignmentDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="/Styles/Controls.axaml" />
    </Application.Styles>
</Application>
