<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:m="clr-namespace:YuCanvas.Models"
             x:Name="Root"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="YuCanvas.Views.Components.Badge"
             x:DataType="m:BadgeModel">
    
    <Border Classes="pill" 
            Background="{StaticResource AccentButtonBackground}"
            BorderBrush="#00000000" 
            Padding="8,2" 
            VerticalAlignment="Center">
        <TextBlock Text="{Binding #Root.Label}" 
                   FontSize="10.5" 
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource AccentButtonForeground}" 
        />
    </Border>
</UserControl>

