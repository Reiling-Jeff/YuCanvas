<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YuCanvas.Models"
             xmlns:viewModels="clr-namespace:YuCanvas.Models.ViewModels"
             x:Class="YuCanvas.Views.AssignmentDetailView"
             x:DataType="viewModels:AssignmentDetailViewModel">

    <ScrollViewer Padding="32,20,32,32">
        <StackPanel Spacing="20">

            <Button Classes="ghost" Command="{Binding GoBackCommand}"
                    HorizontalAlignment="Left" Padding="14,9">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="←" FontSize="15" VerticalAlignment="Center" />
                    <TextBlock Text="Zurück" FontSize="13" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <TextBlock Text="{Binding Name}" Classes="h1" TextWrapping="Wrap" />

            <Border Classes="glass" Padding="22" CornerRadius="18">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="3">
                            <TextBlock Text="Status" Classes="caption" />
                            <TextBlock Text="{Binding StatusText}" Classes="h3" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="Punkte" Classes="caption" />
                            <TextBlock Text="{Binding PointsText}" Classes="h3" />
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="{StaticResource GlassStrokeBrush}" />
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="3">
                            <TextBlock Text="Deadline" Classes="caption" />
                            <TextBlock Text="{Binding DeadlineText}" Classes="body" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="ID" Classes="caption" />
                            <SelectableTextBlock Text="{Binding Id}" Classes="body" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="3">
                        <TextBlock Text="Bewertung" Classes="caption" />
                        <TextBlock Text="{Binding GradeText}" Classes="body" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Beschreibung" Classes="h2" />
            <Border Classes="glass" Padding="22" CornerRadius="18">
                <Border Classes="glass" Padding="22" CornerRadius="18">
                    <TextBlock x:Name="DescriptionBlock" Classes="body" TextWrapping="Wrap"
                               MaxWidth="820" HorizontalAlignment="Left" />
                </Border>
            </Border>

            <Button Classes="accent" Command="{Binding OpenInBrowserCommand}"
                    HorizontalAlignment="Left">
                <TextBlock Text="In Canvas öffnen" FontSize="13.5" />
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
