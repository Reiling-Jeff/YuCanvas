<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:YuCanvas.Models"
             xmlns:viewModels="clr-namespace:YuCanvas.Models.ViewModels"
             xmlns:components="using:YuCanvas.Views.Components"
             x:DataType="viewModels:DashboardViewModel"
             mc:Ignorable="d" d:DesignWidth="1040" d:DesignHeight="1200"
             x:Class="YuCanvas.Views.DashboardView">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
        <StackPanel Margin="32,10,32,32" Spacing="26">

            <Border CornerRadius="24" ClipToBounds="True" Height="188"
                    BorderBrush="{StaticResource GlassStrokeBrightBrush}" BorderThickness="1">
                <Panel>
                    <Border Background="{StaticResource HeroGradient}" />
                    <Border Background="{StaticResource GlowPurple}" Width="420" Height="420"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,-160,-90,0" />
                    <Border Background="{StaticResource GlowPurple}" Width="300" Height="300"
                            Opacity="0.5" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="-120,0,0,-160" />
                    <Grid ColumnDefinitions="*,Auto" Margin="32,28">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="14"
                                    MaxWidth="520" HorizontalAlignment="Left">
                            <Border Classes="pill" Background="#332A6B"
                                    BorderBrush="#4A3D9E" HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="7" Height="7" Fill="{Binding SyncPassedColor}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding LastSyncText}"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="{Binding NextAssignmentDeadline}"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding NextAssignmentText}"
                                       Classes="body" Foreground="#C4CEE6" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Spacing="10" HorizontalAlignment="Right">
                            <Button Classes="accent" Command="{Binding OpenHeroAssignmentCommand}">
                                <TextBlock Text="Zur Aufgabe" FontSize="13.5" />
                            </Button>
                            <Button Classes="ghost disabled" HorizontalContentAlignment="Stretch">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0" Text="Alle Deadlines" FontSize="13" Padding="0, 0 ,10,0" />
                                    <components:Badge Grid.Column="2" Label="Soon"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Panel>
            </Border>

            <Grid ColumnDefinitions="*,16,*,16,*,16,*">
                <Border Grid.Column="0" Classes="stattile">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Ø Note" Classes="caption" />
                            <Border Grid.Column="1" Width="34" Height="34" CornerRadius="10"
                                    Background="#1F34D399">
                                <TextBlock Text="◎" FontSize="15" Foreground="{StaticResource SuccessBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding AverageGrade}" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding DiffAverageGradeLastSemester}" FontSize="12"
                                   Foreground="{StaticResource SuccessBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="stattile">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Offene Aufgaben" Classes="caption" />
                            <Border Grid.Column="1" Width="34" Height="34" CornerRadius="10"
                                    Background="#1FFBBF24">
                                <TextBlock Text="✎" FontSize="15" Foreground="{StaticResource WarnBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding RemainingAssignments}" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding DeadlinesThisWeekText}" FontSize="12"
                                   Foreground="{StaticResource WarnBrush}" />
                    </StackPanel>
                </Border>
                
                <!-- <Border Grid.Column="4" Classes="stattile"> -->
                <!--     <StackPanel Spacing="10"> -->
                <!--         <Grid ColumnDefinitions="*,Auto"> -->
                <!--             <TextBlock Grid.Column="0" Text="Aktive Kurse" Classes="caption" /> -->
                <!--             <Border Grid.Column="1" Width="34" Height="34" CornerRadius="10" -->
                <!--                     Background="#1F8B5CF6"> -->
                <!--                 <TextBlock Text="❏" FontSize="15" Foreground="{StaticResource AccentPurpleBrightBrush}" -->
                <!--                            HorizontalAlignment="Center" VerticalAlignment="Center" /> -->
                <!--             </Border> -->
                <!--         </Grid> -->
                <!--         <TextBlock Text="6" FontSize="30" FontWeight="Bold" -->
                <!--                    Foreground="{StaticResource TextPrimaryBrush}" /> -->
                <!--         <TextBlock Text="18 SWS gesamt" FontSize="12" -->
                <!--                    Foreground="{StaticResource TextMutedBrush}" /> -->
                <!--     </StackPanel> -->
                <!-- </Border> -->

                <Border Grid.Column="4" Grid.ColumnSpan="3" Classes="stattile">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Fortschritt" Classes="caption" />
                            <Border Grid.Column="1" Width="34" Height="34" CornerRadius="10"
                                    Background="#1F38BDF8">
                                <TextBlock Text="◈" FontSize="15" Foreground="{StaticResource InfoBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <TextBlock Text="{Binding ProgressInPercentageText}" FontSize="30" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <ProgressBar Classes="thin" Value="{Binding ProgressInPercentage}" Maximum="100" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,24,360">

                <StackPanel Grid.Column="0" Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Deine Kurse" Classes="h2"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1" Classes="ghost" Padding="14,8">
                            <TextBlock Text="Alle ansehen" FontSize="13" />
                        </Button>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Courses}">

                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border Classes="coursecard" Width="300" Margin="0,0,16,16">
                                    <Panel>
                                        <Border Background="{StaticResource GlassGradient}" />
                                        <Border Height="6" VerticalAlignment="Top"
                                                Background="{StaticResource AccentGradient}" />
                                        <StackPanel Margin="20,22,20,20" Spacing="16">

                                            <Border Width="46" Height="46" CornerRadius="13"
                                                    Background="#242A6B" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Code}" FontSize="16" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentPurpleBrightBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Name}" Classes="h3" />
                                                <TextBlock Text="{Binding Teachers[0].DisplayName}" Classes="caption" />
                                            </StackPanel>

                                            <StackPanel Spacing="7">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Column="0" Text="Fortschritt" FontSize="11.5"
                                                               Foreground="{StaticResource TextMutedBrush}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Progress}" FontSize="11.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </Grid>
                                                <ProgressBar Classes="thin" Value="{Binding Progress}" Maximum="100" />
                                            </StackPanel>

                                        </StackPanel>
                                    </Panel>
                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>
                </StackPanel>

                <StackPanel Grid.Column="2" Spacing="16">
                    <Border Classes="glass" Padding="20">
                        <StackPanel Spacing="16">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Text="Anstehende Deadlines" Classes="h3"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="▤" FontSize="15"
                                           Foreground="{StaticResource AccentPurpleBrightBrush}" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Deadlines}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="0" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding $parent[ItemsControl].((viewModels:DashboardViewModel)DataContext).OpenDeadlineCommand}"
                                                CommandParameter="{Binding}"
                                                Classes="cardbutton"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch">
                                            <Border Classes="listrow">
                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <Border Grid.Column="0" Width="4" Height="38" CornerRadius="2"
                                                            Background="{Binding AccentColor}" Margin="0,0,14,0" />
                                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                                        <TextBlock Text="{Binding Course}" Classes="caption" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                                HorizontalAlignment="Right" Spacing="2">
                                                        <TextBlock Text="{Binding DueLabel}" FontSize="12.5" FontWeight="SemiBold"
                                                                   Foreground="{Binding AccentColor}" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding Relative}" FontSize="11"
                                                                   Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Classes="glass" Padding="20">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Letzte Ankündigungen" Classes="h3" />

                            <ItemsControl ItemsSource="{Binding Announcements}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="14" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>

                                        <StackPanel Spacing="3">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                         Fill="{StaticResource AccentPurpleBrightBrush}"
                                                         IsVisible="{Binding IsUnread}" />
                                                <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                         IsVisible="{Binding !IsUnread}" />
                                                <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Meta}" Classes="caption" Margin="15,0,0,0" />
                                        </StackPanel>

                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
