<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:YuCanvas.Models"
             x:Class="YuCanvas.Views.AssignmentsView"
             x:DataType="vm:AssignmentsViewModel">

    <ScrollViewer Padding="32,20,32,32">
        <StackPanel Spacing="20">

            <TextBlock Text="Aufgaben" Classes="h1" />

            <ItemsControl ItemsSource="{Binding Assignments}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding $parent[ItemsControl].((vm:AssignmentsViewModel)DataContext).OpenAssignmentCommand}"
                                CommandParameter="{Binding}"
                                Classes="cardbutton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch">
                            <Border Classes="glass" Padding="18,16" CornerRadius="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="14.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding CourseName}" Classes="caption" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Classes="pill"
                                            Background="#1F000000" BorderThickness="0"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding StatusColor}" />
                                    </Border>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
